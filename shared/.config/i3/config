set $terminal exec urxvt -title Foo
set $Locker i3lock && sleep 1

set $badwolf_plain #f8f6f2
set $badwolf_snow #ffffff
set $badwolf_coal #000000
set $badwolf_brightgravel #d9cec3
set $badwolf_lightgravel #998f84
set $badwolf_gravel #857f78
set $badwolf_mediumgravel #666462
set $badwolf_deepgravel #45413b
set $badwolf_deepergravel #35322d
set $badwolf_darkgravel #242321
set $badwolf_blackgravel #1c1b1a
set $badwolf_blackestgravel #141413
set $badwolf_dalespale #fade3e
set $badwolf_dirtyblonde #f4cf86
set $badwolf_taffy #ff2c4b
set $badwolf_saltwatertaffy #8cffba
set $badwolf_tardis #0a9dff
set $badwolf_orange #ffa724
set $badwolf_lime #aeee00
set $badwolf_dress #ff9eb8
set $badwolf_toffee #b88853
set $badwolf_coffee #c7915b
set $badwolf_darkroast #88633f

set $molokai_fuschia #F92672
set $molokai_orange #FD971F
set $molokai_purple #AE81FF

# Mod4 = Windows Key
set $mod Mod4
# Mod1 = Alt
set $alt Mod1

focus_follows_mouse no

# polybar (one instance per monitor, shows project-named workspaces)
exec_always --no-startup-id ~/.config/polybar/launch.sh

mode "resize" {
  bindsym j resize shrink height 10 px or 10 ppt
  bindsym k resize grow height 10 px or 10 ppt
  bindsym l resize grow width 10 px or 10 ppt
  bindsym h resize shrink width 10 px or 10 ppt

  # back to normal: Enter or Escape
  bindsym Return mode "default"
  bindsym Escape mode "default"
}

# start a terminal
bindsym $mod+Return $terminal

# kill focused window
bindsym $mod+Shift+q kill

# start dmenu (a program launcher)
bindsym $mod+d exec dmenu_run

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
bindsym $mod+g split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# switch to a project pair: both monitors jump together, focus ends on yoko ($mon1)
bindsym $mod+1 workspace $project1_tate, workspace $project1_yoko
bindsym $mod+2 workspace $project2_tate, workspace $project2_yoko
bindsym $mod+3 workspace $project3_tate, workspace $project3_yoko
bindsym $mod+4 workspace $project4_tate, workspace $project4_yoko
# ensure-dev-terminal auto-launch, disabled for now, uncomment to re-enable:
# bindsym $mod+5 workspace $project5_tate, workspace $project5_yoko, exec --no-startup-id ~/.config/i3/scripts/ensure-dev-terminal.sh "5:MttAi" mtt_ai_dev
# bindsym $mod+6 workspace $project6_tate, workspace $project6_yoko, exec --no-startup-id ~/.config/i3/scripts/ensure-dev-terminal.sh "6:HpbxGUI" hpbxgui_dev
# bindsym $mod+7 workspace $project7_tate, workspace $project7_yoko, exec --no-startup-id ~/.config/i3/scripts/ensure-dev-terminal.sh "7:EqptGUI" eqpt_gui_dev
# bindsym $mod+8 workspace $project8_tate, workspace $project8_yoko, exec --no-startup-id ~/.config/i3/scripts/ensure-dev-terminal.sh "8:TicketsGUI" tickets_dev
# bindsym $mod+9 workspace $project9_tate, workspace $project9_yoko, exec --no-startup-id ~/.config/i3/scripts/ensure-dev-terminal.sh "9:TicketsAPI" tickets_api_dev
bindsym $mod+5 workspace $project5_tate, workspace $project5_yoko
bindsym $mod+6 workspace $project6_tate, workspace $project6_yoko
bindsym $mod+7 workspace $project7_tate, workspace $project7_yoko
bindsym $mod+8 workspace $project8_tate, workspace $project8_yoko
bindsym $mod+9 workspace $project9_tate, workspace $project9_yoko
bindsym $mod+0 workspace $project10_tate, workspace $project10_yoko

bindsym $mod+$alt+1 workspace $project11_tate, workspace $project11_yoko
bindsym $mod+$alt+2 workspace $project12_tate, workspace $project12_yoko
bindsym $mod+$alt+3 workspace $project13_tate, workspace $project13_yoko
bindsym $mod+$alt+4 workspace $project14_tate, workspace $project14_yoko
bindsym $mod+$alt+5 workspace $project15_tate, workspace $project15_yoko
bindsym $mod+$alt+6 workspace $project16_tate, workspace $project16_yoko
bindsym $mod+$alt+7 workspace $project17_tate, workspace $project17_yoko
bindsym $mod+$alt+8 workspace $project18_tate, workspace $project18_yoko
bindsym $mod+$alt+9 workspace $project19_tate, workspace $project19_yoko
bindsym $mod+$alt+0 workspace $project20_tate, workspace $project20_yoko

# move focused container to a project's yoko workspace
bindsym $mod+Shift+1 move container to workspace $project1_yoko
bindsym $mod+Shift+2 move container to workspace $project2_yoko
bindsym $mod+Shift+3 move container to workspace $project3_yoko
bindsym $mod+Shift+4 move container to workspace $project4_yoko
bindsym $mod+Shift+5 move container to workspace $project5_yoko
bindsym $mod+Shift+6 move container to workspace $project6_yoko
bindsym $mod+Shift+7 move container to workspace $project7_yoko
bindsym $mod+Shift+8 move container to workspace $project8_yoko
bindsym $mod+Shift+9 move container to workspace $project9_yoko
bindsym $mod+Shift+0 move container to workspace $project10_yoko

bindsym $mod+$alt+Shift+1 move container to workspace $project11_yoko
bindsym $mod+$alt+Shift+2 move container to workspace $project12_yoko
bindsym $mod+$alt+Shift+3 move container to workspace $project13_yoko
bindsym $mod+$alt+Shift+4 move container to workspace $project14_yoko
bindsym $mod+$alt+Shift+5 move container to workspace $project15_yoko
bindsym $mod+$alt+Shift+6 move container to workspace $project16_yoko
bindsym $mod+$alt+Shift+7 move container to workspace $project17_yoko
bindsym $mod+$alt+Shift+8 move container to workspace $project18_yoko
bindsym $mod+$alt+Shift+9 move container to workspace $project19_yoko
bindsym $mod+$alt+Shift+0 move container to workspace $project20_yoko

# flip the focused window between the yoko and tate half of its current project pair
bindsym $mod+o exec --no-startup-id ~/.config/i3/scripts/toggle-yoko-tate.sh

# reload the configuration file
bindsym $mod+Shift+c reload

# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec i3-msg exit

# lock
bindsym $mod+Shift+p exec --no-startup-id $Locker

# enter resize mode
bindsym $mod+r mode "resize"

# no title, width 3 border
new_window pixel 6

# font
font pango:Hack Nerd Font 12

# gaps
smart_gaps on
gaps outer 0
gaps inner 16
smart_borders on

#                       border                  background    text          indicator               child_border
client.focused          $badwolf_tardis         $badwolf_coal $badwolf_snow $badwolf_tardis         $badwolf_tardis
client.focused_inactive $badwolf_blackestgravel $badwolf_coal $badwolf_snow $badwolf_blackestgravel $badwolf_blackestgravel
client.unfocused        $badwolf_blackestgravel $badwolf_coal $badwolf_snow $badwolf_blackestgravel $badwolf_blackestgravel
