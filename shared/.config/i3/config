set $mon1 DP-1
set $mon2 HDMI-1

# Project workspace pairs: $mod+N switches both monitors at once (yoko = $mon1,
# tate = $mon2). $mod+1..0 covers slots 1-10, $mod+alt+1..0 covers slots 11-20.
# Names are generic for now (ProjectA..ProjectT) and get renamed per-project later.
set $project1_yoko   "1:Home"
set $project1_tate   "1b:Home"
set $project2_yoko   "2:Browser"
set $project2_tate   "2b:Browser"
set $project3_yoko   "3:Chat"
set $project3_tate   "3b:Chat"
set $project4_yoko   "4:ProjectD"
set $project4_tate   "4b:ProjectD"
