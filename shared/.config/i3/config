set $project7_tate   "7b:EqptGUI"
set $project8_yoko   "8:TicketsGUI"
set $project8_tate   "8b:TicketsGUI"
set $project9_yoko   "9:TicketsAPI"
set $project9_tate   "9b:TicketsAPI"
set $project10_yoko  "10:Troubleshoot"
set $project10_tate  "10b:Troubleshoot"

set $project11_yoko  "11:ProjectK"
set $project11_tate  "11b:ProjectK"
